# Copy to .env and fill in. Loaded by pydantic-settings (config.py) and docker-compose.
# Never commit the real .env — only this example is tracked.

# ── Postgres (consumed by docker-compose `db` service) ──────────────────────────
POSTGRES_USER=wealth
POSTGRES_PASSWORD=wealth
POSTGRES_DB=wealth
POSTGRES_TEST_DB=wealth_test
POSTGRES_PORT=5432
APP_PORT=8000

# ── Application ────────────────────────────────────────────────────────────────
# In compose, DATABASE_URL is derived from the POSTGRES_* vars above and points at
# the `db` service. For host-side runs (e.g. local pytest/alembic) use localhost:
# DATABASE_URL=postgresql+psycopg://wealth:wealth@localhost:5432/wealth

# Auth — MUST be >= 32 bytes (RFC 7518). Generate: openssl rand -hex 32
JWT_SECRET=replace-with-32-byte-minimum-random-secret-0000

# Encryption-at-rest — base64-encoded 32-byte AES key. Generate:
#   python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key

# Account aggregation: "fake" (offline, deterministic) or "plaid"
AGGREGATION_PROVIDER=fake

# Plaid sandbox (only when AGGREGATION_PROVIDER=plaid)
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox

# Weekly snapshot job — keep false until the pipeline is validated end-to-end
SNAPSHOT_JOB_ENABLED=false
